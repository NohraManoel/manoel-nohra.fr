---
// src/components/ResumeContent.astro
import { translations } from '../data/translations';
import { resumeData } from '../data/resume';

interface Props {
  lang: 'en' | 'fr';
}

const { lang } = Astro.props;
const t = translations[lang];
const data = resumeData[lang];
---

<div class="resume-container animate-fade-in">
  <h1>{t.journeyTitle}</h1>
  
  <div class="skills-block">
    <h2>{t.skillsTitle}</h2>
    <ul>
      <li><strong>{t.skillsEngines}:</strong> Anvil (Ubisoft), Unreal Engine 5, Unity, Wwise</li>
      <li><strong>{t.skillsLanguages}:</strong> C++, C#, WPF, XAML</li>
      <li><strong>{t.skillsTools}:</strong> Git, Debugging, Optimization, Agile/Teamwork</li>
    </ul>
  </div>

  <div class="timeline-section">
    <h2>{t.timelineInternships}</h2>
    <div class="timeline">
      {data.internships.map((item) => (
        <div class="timeline-item">
          <span class="date">{item.date}</span>
          <h3>{item.title}</h3>
          <span class="location">{item.subtitle}</span>
          {item.bullets && item.bullets.length > 0 && (
            <ul>
              {item.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </div>

  <div class="timeline-section">
    <h2>{t.timelineEducation}</h2>
    <div class="timeline">
      {data.education.map((item) => (
        <div class="timeline-item">
          <span class="date">{item.date}</span>
          <h3>{item.title}</h3>
          <span class="institution">{item.subtitle}</span>
          {item.description && <p>{item.description}</p>}
        </div>
      ))}
    </div>
  </div>

  <div class="timeline-section">
    <h2>{t.timelineExtracurricular}</h2>
    <div class="timeline">
      {data.extracurriculars.map((item) => (
        <div class="timeline-item">
          <span class="date">{item.date}</span>
          <h3>{item.title}</h3>
          <span class="location">{item.subtitle}</span>
          {item.bullets && item.bullets.length > 0 && (
            <ul>
              {item.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .resume-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  /* Fade-in Animation */
  .animate-fade-in {
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: #fff;
  }

  h2 {
    font-size: 1.6rem;
    color: var(--accent-light);
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
  }

  .skills-block {
    background-color: var(--bg-card);
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 3rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .skills-block ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
  }

  .skills-block li {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .skills-block li strong {
    color: #fff;
  }

  .timeline-section {
    margin-bottom: 3rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-item {
    border-left: 2px solid var(--accent);
    padding-left: 1.5rem;
    position: relative;
    transition: transform 0.2s ease;
  }

  /* Hover effect for timeline items to make it premium */
  .timeline-item:hover {
    transform: translateX(4px);
  }

  .timeline-item::before {
    content: "";
    position: absolute;
    left: -6px;
    top: 4px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--bg-dark);
    border: 2px solid var(--accent-light);
    transition: background-color 0.2s ease;
  }

  .timeline-item:hover::before {
    background-color: var(--accent-light);
  }

  .date {
    font-size: 0.85rem;
    color: var(--accent-light);
    font-weight: 600;
    display: block;
  }

  .timeline-item h3 {
    margin: 0.25rem 0 0.1rem 0;
    color: #fff;
    font-size: 1.25rem;
  }

  .location, .institution {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-style: italic;
    display: block;
    margin-bottom: 0.75rem;
  }

  .timeline-item p {
    color: var(--text-main);
    line-height: 1.5;
  }

  .timeline-item ul {
    padding-left: 1.2rem;
    color: var(--text-main);
    line-height: 1.5;
  }

  .timeline-item li {
    margin-bottom: 0.25rem;
  }
</style>
