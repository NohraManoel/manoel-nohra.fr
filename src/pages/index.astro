---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
---
<BaseLayout title="Home">
  <section class="hero">
    <h1>Welcome ! <br> I am <span class="highlight">Manoël Nohra</span></h1>
    <p>Welcome to my portfolio where I showcase my projects and experiences.</p>
  </section>

  <section class="about-section">
    <h2>About Me</h2>
    <p class="about-lead">
      My name is Manoël Nohra, I am 23 years old and I graduated from a Bachelor's degree in Software Engineering at École de technologie supérieure in Montreal in April 2026. My professional goal is to become a gameplay programmer in the video game industry.
    </p>
    
    <div class="about-content">
      <div class="about-profile">
        <img src="/images/profile.jpg" alt="Manoël Nohra" class="profile-img" />
      </div>
      
      <div class="about-details">
        <h3>Software Engineer</h3>

        <ul class="details-list">
          <li><strong>Date of birth:</strong> October 30, 2002</li>
          <li><strong>Age:</strong> 23 years old</li>
          <li><strong>Website:</strong> manoel-nohra.fr</li>
          <li><strong>Degree:</strong> Bachelor in Software Engineering</li>
          <li><strong>Phone:</strong> <span>06 26 61 10 36 (FR)</span><br><span class="phone-space">438-228-4931 (CA)</span></li>
          <li><strong>Email:</strong> manoel.nohra@gmail.com</li>
          <li><strong>City:</strong> Montreal, Quebec, Canada</li>
        </ul>

        <div class="favorite-games-container">
          <h4>Favorite Games</h4>
          <div class="games-tags">
            <span class="game-tag">Rocket League <small>(SSL)</small></span>
            <span class="game-tag">Metaphor: ReFantazio</span>
            <span class="game-tag">Final Fantasy X</span>
            <span class="game-tag">Hollow Knight: Silksong</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="games-section">
    <h2>My Games</h2>
    <div class="games-grid">
        <GameCard 
            title="Panic On Comic City !" 
            description="🏆 Won Best Accessibility Award & Nominated for Best Design and Best Technical Innovation at the Ubisoft Gamelab 2026. An asymmetrical co-op game with an 80s-90s theme, developed over 10 weeks. Players team up as a roller and a snake to maximize their score, featuring flexible controls supporting dual gamepads, keyboard co-op, or solo keyboard play."
            tags={["Unity", "Co-op", "PC", "Ubisoft 2026"]}
            media={[
                "https://youtu.be/0Q0UfIkH1_U?si=NZDiEOollDZ2e6AY",
                "/images/POCC/InGame.png"
            ]}
            link="https://manoelnohra.itch.io/panic-on-comic-city"
        />
        <GameCard 
            title="Urbia" 
            description="A city-building simulation game developed on Unity for pedagogical purposes within the Urban Planning department at Cégep de Matane. Acted as a Programmer to resume development on an existing codebase where players must grow a city, manage resource constraints, and balance the escalating demands of an expanding population."
            tags={["Unity", "Simulation", "Internship", "2022"]}
            media={[
                "https://youtu.be/nk9_qUVzghE?si=rDdCwFjEgHM44uc4",
                "/images/Urbia/TitleScreen.png",
                "/images/Urbia/InGame.png",
                "/images/Urbia/InGameAdvanced.png"
            ]}
            link="https://dev.timmatane.ca/urbia"
        />
        <GameCard 
            title="The Plague" 
            description="🏆 Best Sound Design. A top-down, procedurally generated game developed in 48 hours during the Montreal GameJam. Reversing traditional roles, you play as the Black Plague with the objective of hunting down the doctor before he gathers a cure. Features a variety of gameplay abilities including a tracking radar, a dash mechanics, slows, and a passive infection zone to corrupt civilians and expand your vision."
            tags={["Unity", "GameJam", "2023"]}
            media={[
                "https://youtu.be/BIpkwAC2xWw?si=C1dIM_8RxTfAh0s6"
            ]}
            link="https://manoelnohra.itch.io/the-plague"
        />
		<GameCard 
            title="Tower Defense Prototype" 
            description="Used Unreal Engine 5 to create a tower defense prototype during my free time. The game is as basic as a Tower Defense, I may expend the game into a roguelike if the design comes up nice. I developed the core mechanics of the game, including enemy pathfinding, tower placement, and wave management, while also implementing a simple UI to display player health and resources."
            tags={["Unreal Engine 5", "Tower Defense", "2025"]}
            media={[
                "/images/TD/InGame1.png",
                "/images/TD/InGame.png",
                "/images/TD/InGame3.png",
            ]}
            link="https://github.com/NohraManoel/TD"
        />
        <GameCard 
            title="The Legend of Jaloux" 
            description="A 2D tactical turn-based strategy game set in a medieval fantasy dungeon. Lead a hero through rooms, gain experience, open chests, and manage action points to defeat the final boss. Developed in a team of 6 during my Computer Science degree."
			tags={["Unity", "2021"]}
            media={[
            "https://www.youtube.com/watch?v=PtGLqUkL84o",
            "/images/Jaloux/TitleJaloux.png",
            "/images/Jaloux/CarteJaloux.png",
            "/images/Jaloux/MenuJaloux.png",
            "/images/Jaloux/JeuJaloux.png",
            ]}
            link="https://github.com/Chopv1/The-legend-of-Jaloux"
        />
        <GameCard 
            title="Specialized FPS Project" 
            description="A solo first-person shooter featuring dynamic movement mechanics such as double jumping, grappling, sliding, and ricochet shooting. Each level restricts or enables specific mechanics, forcing the player to adapt. Developed independently under faculty supervision during my exchange semester at Matane."
            tags={["Unreal Engine 4", "FPS", "2023"]}
            media={[
                "https://youtu.be/r7Ow_lh_vSI?si=llbNVUJL-147jwR5",
                "/images/FPS/gameStart.png",
            ]}
            link="https://github.com/cegepmatane/projet-specialise-2022-ManoelNohra"
            />
    </div>
  </section>
</BaseLayout>

<style>
  /* Centrage global du contenu de la page */
  .hero, .about-section, .games-section {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* Style de la section d'introduction */
  .hero {
    text-align: center;
    padding: 4rem 1rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: #fff;
  }

  .hero .highlight {
    color: var(--accent-light, #60a5fa);
    font-weight: 700;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--text-muted, #94a3b8);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Titres de sections */
  .about-section h2, .games-section h2 {
    font-size: 2rem;
    color: #fff;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
  }

  /* Section About Me */
  .about-lead {
    color: var(--text-main, #e2e8f0);
    line-height: 1.6;
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }

  .about-content {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .about-profile {
    flex-shrink: 0;
    width: 300px;
  }

  .profile-img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    object-fit: cover;
  }

  .about-details {
    flex: 1;
  }

  .about-details h3 {
    font-size: 1.5rem;
    color: var(--accent-light, #60a5fa);
    margin-bottom: 1.5rem;
  }

  .details-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem 2rem;
  }

  .details-list li {
    color: var(--text-main, #e2e8f0);
    line-height: 1.4;
    position: relative;
    padding-left: 1.2rem;
  }

  /* Flèche devant chaque élément de liste */
  .details-list li::before {
    content: "›";
    position: absolute;
    left: 0;
    top: -2px;
    color: var(--accent-light, #60a5fa);
    font-size: 1.2rem;
    font-weight: bold;
  }

  .details-list strong {
    color: #fff;
  }

  .phone-space {
    padding-left: 0;
    display: inline-block;
    margin-top: 0.2rem;
  }

  /* Grille réactive pour les GameCards */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
    gap: 2.5rem;
  }

  /* Ajustements pour tablettes et mobiles */
  @media (max-width: 768px) {
    .about-content {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }
    .about-profile {
      width: 250px;
    }
    .details-list {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 500px) {
    .games-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .hero h1 {
      font-size: 2.2rem;
    }
  }
  /* --- Section Jeux Favoris --- */
  .favorite-games-container {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .favorite-games-container h4 {
    font-size: 1.1rem;
    color: #fff;
    margin: 0 0 0.8rem 0;
    position: relative;
    padding-left: 1.2rem;
  }

  /* Reprise de la flèche pour garder une cohérence visuelle */
  .favorite-games-container h4::before {
    content: "›";
    position: absolute;
    left: 0;
    top: -3px;
    color: var(--accent-light, #60a5fa);
    font-size: 1.2rem;
    font-weight: bold;
  }

  .games-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .game-tag {
    background-color: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    color: var(--accent-light, #60a5fa);
    padding: 0.3rem 0.8rem;
    border-radius: 20px; /* Bords bien arrondis style capsule */
    font-size: 0.9rem;
    font-weight: 500;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .game-tag small {
    color: #94a3b8;
    font-weight: normal;
    margin-left: 0.2rem;
  }

  /* Petit effet interactif discrets au survol */
  .game-tag:hover {
    background-color: rgba(59, 130, 246, 0.2);
    border-color: var(--accent-light, #60a5fa);
  }
</style>