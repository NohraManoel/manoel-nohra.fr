---
// src/pages/fr/parcours.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Mon Parcours">
  <section class="parcours-container">
    <h1>Mon Parcours</h1>
    
    <div class="skills-block">
      <h2>Aperçu des compétences techniques</h2>
      <ul>
        <li><strong>Moteurs & Audio :</strong> Anvil (Ubisoft), Unreal Engine 5, Unity, Wwise</li>
        <li><strong>Langages & Frameworks :</strong> C++, C#, WPF, XAML</li>
        <li><strong>Outils & Méthodes :</strong> Git, Débogage, Optimisation, Travail d'équipe / Agile</li>
      </ul>
    </div>

    <div class="timeline-section">
      <h2>Expériences de Stage</h2>
      <div class="timeline">
        
        <div class="timeline-item">
          <span class="date">Mai 2025 - Août 2025 (Stage de 17 semaines)</span>
          <h3>Stagiaire Programmeur Gameplay — Ubisoft Montréal</h3>
          <span class="location">Montréal, Québec, Canada</span>
          <ul>
            <li>Apprentissage et travail sur un moteur de jeu interne (Anvil).</li>
            <li>Débogage et résolution de problèmes complexes.</li>
            <li>Création de systèmes pour simplifier l'intégration des fonctionnalités par les designers.</li>
            <li>Ajout de fonctionnalités au moteur de jeu et tests du jeu.</li>
            <li>Travail en équipe et vulgarisation de termes techniques pour les parties prenantes non techniques.</li>
          </ul>
        </div>

        <div class="timeline-item">
          <span class="date">Septembre 2024 - Décembre 2024 (Stage de 15 semaines)</span>
          <h3>Stagiaire Ingénieur Logiciel — Audiokinetic</h3>
          <span class="location">Montréal, Québec, Canada</span>
          <ul>
            <li>Approfondissement des connaissances sur Unreal Engine 5 et Unity.</li>
            <li>Création d'un système d'environnement audio dynamique facilement personnalisable pour les designers.</li>
            <li>Travail autonome, recherche et documentation efficace de solutions techniques.</li>
            <li>Préparation de présentations techniques et intégration d'idées originales en production.</li>
            <li>Recherche de solutions à des problèmes complexes et explications claires des termes techniques.</li>
          </ul>
        </div>

        <div class="timeline-item">
          <span class="date">Janvier 2024 - Mai 2024 (Stage de 16 semaines)</span>
          <h3>Stagiaire Programmeur Outils — Ubisoft Montréal</h3>
          <span class="location">Montréal, Québec, Canada</span>
          <ul>
            <li>Apprentissage et adoption d'un nouveau framework et langage de programmation (WPF et XAML).</li>
            <li>Travail en équipe, adaptation aux directives de sécurité et aux normes de style de code.</li>
            <li>Recherche de solutions d'optimisation et résolution de bugs logiciels complexes.</li>
          </ul>
        </div>

        <div class="timeline-item">
          <span class="date">2022 (Stage de 10 semaines)</span>
          <h3>Stagiaire Programmeur (Projet de jeu vidéo Urbia) — CDRIN</h3>
          <span class="location">Matane, Québec, Canada</span>
          <ul>
            <li>Évaluation, analyse des besoins clients et communication efficace avec le client et l'équipe.</li>
            <li>Adaptation à une base de code externe préexistante.</li>
            <li>Apport d'idées novatrices au projet et résolution de problèmes de développement complexes.</li>
            <li>Explications claires des éléments techniques au client.</li>
          </ul>
        </div>

        <div class="timeline-item">
          <span class="date">2018 (2 semaines)</span>
          <h3>Stagiaire Technicien Helpdesk — Econocom</h3>
          <span class="location">Grenoble, France</span>
          <ul>
            <li>Évaluation et analyse des situations clients.</li>
            <li>Proposition de solutions techniques adaptées.</li>
          </ul>
        </div>

      </div>
    </div>

    <div class="timeline-section">
      <h2>Éducation & Formations</h2>
      <div class="timeline">

        <div class="timeline-item">
          <span class="date">Septembre 2022 - Avril 2026</span>
          <h3>Baccalauréat en Génie Logiciel (Diplômé)</h3>
          <span class="institution">École de technologie supérieure (ÉTS), Montréal, Québec, Canada</span>
          <p>Un programme de 4 ans pour devenir ingénieur logiciel, comprenant 3 stages obligatoires.</p>
        </div>

        <div class="timeline-item">
          <span class="date">2022</span>
          <h3>Session 4 au Québec (Études à l'étranger)</h3>
          <span class="institution">Cégep de Matane, Matane, Québec, Canada</span>
          <p>Dernier semestre de mon DUT effectué dans un cégep au Québec pour l'obtention du diplôme.</p>
        </div>

        <div class="timeline-item">
          <span class="date">2022</span>
          <h3>Diplôme Universitaire de Technologie en Informatique (DUT)</h3>
          <span class="institution">Université Claude Bernard Lyon 1, France</span>
          <p>Apprentissage des fondements de l'informatique, découverte du développement logiciel et acquisition de connaissances techniques avancées.</p>
        </div>

        <div class="timeline-item">
          <span class="date">2020</span>
          <h3>Baccalauréat Scientifique, Spécialité Mathématiques</h3>
          <span class="institution">Lycée Saint Jean Bosco, Cluses, France</span>
          <p>Obtenu avec mention Bien.</p>
        </div>

      </div>
    </div>

    <div class="timeline-section">
      <h2>Implication Extrascolaire</h2>
      <div class="timeline">

        <div class="timeline-item">
          <span class="date">Septembre 2022 - Août 2025</span>
          <h3>Club EsporTS — Joueur de l'alignement principal (Équipe 1 Rocket League)</h3>
          <span class="location">ÉTS, Montréal, Québec, Canada</span>
          <ul>
            <li>Participation à des ligues et tournois compétitifs, gestion du stress lors de matchs intenses.</li>
            <li>Organisation d'événements du club (tournois, LAN) et communication intra/inter-équipes.</li>
            <li>Analyse des données de jeu et préparation de sessions d'entraînement individuelles et collectives.</li>
          </ul>
        </div>

        <div class="timeline-item">
          <span class="date">2022</span>
          <h3>Club Conjure (Club de création de jeux vidéo) — Membre</h3>
          <span class="location">ÉTS, Montréal, Québec, Canada</span>
          <ul>
            <li>Organisation d'événements (Gala, GameJam) et participation à des GameJams.</li>
            <li>Travail en équipe pour résoudre des problèmes de projet sous des délais serrés.</li>
          </ul>
        </div>

      </div>
    </div>

  </section>
</BaseLayout>

<style>
  .parcours-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: #fff;
  }

  h2 {
    font-size: 1.6rem;
    color: var(--accent-light);
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
  }

  .skills-block {
    background-color: var(--bg-card);
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 3rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .skills-block ul {
    list-style-type: none;
  }

  .skills-block li {
    margin-bottom: 0.5rem;
  }

  .timeline-section {
    margin-bottom: 3rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-item {
    border-left: 2px solid var(--accent);
    padding-left: 1.5rem;
    position: relative;
  }

  .date {
    font-size: 0.85rem;
    color: var(--accent-light);
    font-weight: 600;
    display: block;
  }

  .timeline-item h3 {
    margin: 0.25rem 0 0.1rem 0;
    color: #fff;
    font-size: 1.25rem;
  }

  .location, .institution {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-style: italic;
    display: block;
    margin-bottom: 0.75rem;
  }

  .timeline-item p {
    color: var(--text-main);
    line-height: 1.5;
  }

  .timeline-item ul {
    padding-left: 1.2rem;
    color: var(--text-main);
    line-height: 1.5;
  }

  .timeline-item li {
    margin-bottom: 0.25rem;
  }
</style>