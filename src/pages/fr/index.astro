---
// src/pages/fr/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameCard from '../../components/GameCard.astro';
---
<BaseLayout title="Accueil">
  <!-- Section d'introduction épurée -->
  <section class="hero">
    <h1>Bienvenue ! <br> Je suis <span class="highlight">Manoël Nohra</span></h1>
    <p>Bienvenue sur mon portfolio où je présente mes projets et mes expériences.</p>
  </section>

  <!-- Section À Propos -->
  <section class="about-section">
    <h2>À Propos de Moi</h2>
    <p class="about-lead">
      Je m'appelle Manoël Nohra, j'ai 23 ans et je suis diplômé d'un baccalauréat en génie logiciel à l'École de technologie supérieure de Montréal depuis avril 2026. Mon objectif professionnel est de devenir programmeur gameplay dans l'industrie du jeu vidéo.
    </p>
    
    <div class="about-content">
      <div class="about-profile">
        <img src="/images/profile.jpg" alt="Manoël Nohra" class="profile-img" />
      </div>
      
      <div class="about-details">
        <h3>Ingénieur Logiciel</h3>
        <ul class="details-list">
          <li><strong>Date de naissance :</strong> 30 octobre 2002</li>
          <li><strong>Âge :</strong> 23 ans</li>
          <li><strong>Site web :</strong> manoel-nohra.fr</li>
          <li><strong>Diplôme :</strong> Baccalauréat en Génie Logiciel</li>
          <li><strong>Téléphone :</strong> <span>06 26 61 10 36 (FR)</span><br><span class="phone-space">438-228-4931 (CA)</span></li>
          <li><strong>Courriel :</strong> manoel.nohra@gmail.com</li>
          <li><strong>Ville :</strong> Montréal, Québec, Canada</li>
        </ul>
        <div class="favorite-games-container">
          <h4>Jeux Favoris</h4>
          <div class="games-tags">
            <span class="game-tag">Rocket League <small>(SSL)</small></span>
            <span class="game-tag">Metaphor: ReFantazio</span>
            <span class="game-tag">Final Fantasy X</span>
            <span class="game-tag">Hollow Knight: Silksong</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section des projets avec grille optimisée -->
  <section class="games-section">
    <h2>Mes Jeux</h2>
    <div class="games-grid">
        <GameCard 
            title="Panic On Comic City !" 
            description="🏆 Nous avons remporté le prix de la Meilleure Accessibilité & Nommé pour le Meilleur Design et la Meilleure Innovation Technique au Concours Universtaire Ubisoft 2026. Un jeu de coopération asymétrique sur le thème des années 80-90, développé en 10 semaines. Les joueurs font équipe en incarnant un roller et un serpent pour maximiser leur score. Propose des contrôles flexibles compatibles avec deux manettes, un combo manette/clavier ou un clavier seul."
            tags={["Unity", "Co-op", "PC", "Ubisoft 2026"]}
            media={[
                "https://youtu.be/0Q0UfIkH1_U?si=NZDiEOollDZ2e6AY",
                "/images/POCC/InGame.png"
            ]}
            link="https://manoelnohra.itch.io/panic-on-comic-city"
        />
        <GameCard 
            title="Urbia" 
            description="Un jeu de simulation de construction de ville développé sur Unity à des fins pédagogiques pour le département d'urbanisme du Cégep de Matane. J'ai agi en tant que programmeur pour reprendre le développement sur une base de code existante, les joueurs doivent agrandir une ville, gérer les contraintes de ressources et équilibrer les demandes croissantes d'une population en pleine expansion."
            tags={["Unity", "Simulation", "Stage", "2022"]}
            media={[
                "https://youtu.be/nk9_qUVzghE?si=rDdCwFjEgHM44uc4",
                "/images/Urbia/TitleScreen.png",
                "/images/Urbia/InGame.png",
                "/images/Urbia/InGameAdvanced.png"
            ]}
            link="https://dev.timmatane.ca/urbia"
        />
        <GameCard 
            title="The Plague" 
            description="🏆 Meilleure Sound Design. Un jeu en vue de dessus généré de manière procédurale, développé en 48 heures lors de la Montreal GameJam. Vous incarnez la peste noire avec pour objectif de traquer le médecin avant qu'il ne trouve un remède. Propose diverses compétences de gameplay incluant un radar de suivi, une mécanique de dash, des ralentissements et une zone d'infection passive pour corrompre les civils et étendre votre vision."
            tags={["Unity", "GameJam", "2023"]}
            media={[
                "https://youtu.be/BIpkwAC2xWw?si=C1dIM_8RxTfAh0s6"
            ]}
            link="https://manoelnohra.itch.io/the-plague"
        />
        <GameCard 
            title="Tower Defense Prototype" 
            description="Utilisation d'Unreal Engine 5 pour créer un prototype de tower defense pendant mon temps libre. Le jeu repose sur les bases classiques du genre, avec la possibilité de faire évoluer le design vers un roguelike. J'ai développé les mécaniques fondamentales du jeu, notamment le pathfinding des ennemis, le placement des tours et la gestion des vagues, tout en implémentant une interface utilisateur simple pour afficher la santé et les ressources du joueur."
            tags={["Unreal Engine 5", "Tower Defense", "2025"]}
            media={[
                "/images/TD/InGame1.png",
                "/images/TD/InGame.png",
                "/images/TD/InGame3.png",
            ]}
            link="https://github.com/NohraManoel/TD"
        />
        <GameCard 
            title="The Legend of Jaloux" 
            description="Un jeu de stratégie tactique en 2D au tour par tour se déroulant dans un donjon médiéval-fantastique. Dirigez un héros à travers les salles, gagnez de l'expérience, ouvrez des coffres et gérez vos points d'action pour vaincre le boss final. Développé en équipe de 6 personnes durant mon cursus universitaire en informatique."
            tags={["Unity", "2021"]}
            media={[
                "https://www.youtube.com/watch?v=PtGLqUkL84o",
                "/images/Jaloux/TitleJaloux.png",
                "/images/Jaloux/CarteJaloux.png",
                "/images/Jaloux/MenuJaloux.png",
                "/images/Jaloux/JeuJaloux.png",
            ]}
            link="https://github.com/Chopv1/The-legend-of-Jaloux"
        />
        <GameCard 
            title="Specialized FPS Project" 
            description="Un jeu de tir à la première personne solo mettant en scène des mécaniques de mouvement dynamiques telles que le double saut, le grappin, la glissade et les tirs par ricochet. Chaque niveau restreint ou active des mécaniques spécifiques, forçant le joueur à s'adapter. Développé de manière autonome sous la supervision des professeurs lors de mon semestre d'échange à Matane."
            tags={["Unreal Engine 4", "FPS", "2023"]}
            media={[
                "https://youtu.be/r7Ow_lh_vSI?si=llbNVUJL-147jwR5",
                "/images/FPS/gameStart.png",
            ]}
            link="https://github.com/cegepmatane/projet-specialise-2022-ManoelNohra"
        />
    </div>
  </section>
</BaseLayout>

<style>
  /* Centrage global du contenu de la page */
  .hero, .about-section, .games-section {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* Style de la section d'introduction */
  .hero {
    text-align: center;
    padding: 4rem 1rem;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: #fff;
  }

  .hero .highlight {
    color: var(--accent-light, #60a5fa);
    font-weight: 700;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--text-muted, #94a3b8);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Titres de sections */
  .about-section h2, .games-section h2 {
    font-size: 2rem;
    color: #fff;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
  }

  /* Section About Me */
  .about-lead {
    color: var(--text-main, #e2e8f0);
    line-height: 1.6;
    margin-bottom: 2rem;
    font-size: 1.05rem;
  }

  .about-content {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .about-profile {
    flex-shrink: 0;
    width: 300px;
  }

  .profile-img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    object-fit: cover;
  }

  .about-details {
    flex: 1;
  }

  .about-details h3 {
    font-size: 1.5rem;
    color: var(--accent-light, #60a5fa);
    margin-bottom: 1.5rem;
  }

  .details-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem 2rem;
  }

  .details-list li {
    color: var(--text-main, #e2e8f0);
    line-height: 1.4;
    position: relative;
    padding-left: 1.2rem;
  }

  /* Flèche devant chaque élément de liste */
  .details-list li::before {
    content: "›";
    position: absolute;
    left: 0;
    top: -2px;
    color: var(--accent-light, #60a5fa);
    font-size: 1.2rem;
    font-weight: bold;
  }

  .details-list strong {
    color: #fff;
  }

  .phone-space {
    padding-left: 0;
    display: inline-block;
    margin-top: 0.2rem;
  }

  /* Grille réactive pour les GameCards */
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
    gap: 2.5rem;
  }

  /* Ajustements pour tablettes et mobiles */
  @media (max-width: 768px) {
    .about-content {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }
    .about-profile {
      width: 250px;
    }
    .details-list {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 500px) {
    .games-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .hero h1 {
      font-size: 2.2rem;
    }
  }
  /* --- Section Jeux Favoris --- */
  .favorite-games-container {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .favorite-games-container h4 {
    font-size: 1.1rem;
    color: #fff;
    margin: 0 0 0.8rem 0;
    position: relative;
    padding-left: 1.2rem;
  }

  /* Reprise de la flèche pour garder une cohérence visuelle */
  .favorite-games-container h4::before {
    content: "›";
    position: absolute;
    left: 0;
    top: -3px;
    color: var(--accent-light, #60a5fa);
    font-size: 1.2rem;
    font-weight: bold;
  }

  .games-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .game-tag {
    background-color: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    color: var(--accent-light, #60a5fa);
    padding: 0.3rem 0.8rem;
    border-radius: 20px; /* Bords bien arrondis style capsule */
    font-size: 0.9rem;
    font-weight: 500;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .game-tag small {
    color: #94a3b8;
    font-weight: normal;
    margin-left: 0.2rem;
  }

  /* Petit effet interactif discrets au survol */
  .game-tag:hover {
    background-color: rgba(59, 130, 246, 0.2);
    border-color: var(--accent-light, #60a5fa);
  }
</style>